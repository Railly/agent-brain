filters:
  and:
    - file.inFolder("03_Garden/concepts")
    - type == "concept"
properties:
  themes:
    displayName: Themes
  sources:
    displayName: Sources
  people:
    displayName: People
  created:
    displayName: Created
  rating:
    displayName: Rating
views:
  - type: table
    name: Recently Created
    order:
      - file.name
      - themes
      - sources
      - created
    sort:
      - property: created
        direction: DESC
  - type: table
    name: All Concepts
    order:
      - file.name
      - themes
      - sources
      - people
      - created
    sort:
      - property: file.name
        direction: ASC
  - type: table
    name: By Theme
    groupBy:
      property: themes
      direction: ASC
    order:
      - file.name
      - sources
      - created
  - type: table
    name: With People
    filters:
      and:
        - people != null
    order:
      - file.name
      - people
      - themes
      - created
  - type: table
    name: Rated
    filters:
      and:
        - rating != null
    order:
      - file.name
      - rating
      - themes
      - created
    sort:
      - property: rating
        direction: DESC
